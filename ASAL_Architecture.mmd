flowchart LR
  subgraph S[Substrate S(θ)]
    A[Substrate Registry\n(Boids / ParticleLife / Lenia / NCA / Life-like CA)]
    B[Simulation Runner\n(T steps, seeds)]
    C[Renderer → Images/Video]
    A --> B --> C
  end

  subgraph FM[Foundation Model]
    V1[VLM_img (CLIP/DINOv2)]
    V2[VLM_txt (prompt)]
  end

  subgraph SC[ASAL Scorers]
